   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import Dataset, DataLoader, TensorDataset, random_split\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import random\n",
    "import time\n",
    "import gc\n",
    "from sklearn.metrics import confusion_matrix, accuracy_score\n",
    "\n",
    "# ── Reproducibility (adapted from E2E_Regression_Anis_Ismail/main.py) ──\n",
    "SEED = 42\n",
    "np.random.seed(SEED)\n",
    "torch.manual_seed(SEED)\n",
    "random.seed(SEED)\n",
    "if torch.cuda.is_available():\n",
    "    torch.cuda.manual_seed_all(SEED)\n",
    "    torch.backends.cudnn.deterministic = True\n",
    "    torch.backends.cudnn.benchmark = False\n",
    "\n",
    "# ── Device ──\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f\"Using device: {device}\")\n",
    "if device.type == 'cuda':\n",
    "    print(f\"GPU: {torch.cuda.get_device_name(0)}\")\n",
    "    print(f\"Memory: {torch.cuda.get_device_properties(0).total_mem / 1e9:.1f} GB\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SECTION 3 — Detector Data Representation\n",
    "\n",
    "CMS detector images have shape **(B, 3, 125, 125)** where the 3 channels are:\n",
    "- **Channel 0 (Tracker):** charged particle tracks — scaled by 0.02 in the E2E pipeline  \n",
    "- **Channel 1 (ECAL):** electromagnetic energy deposits — scaled by 0.2  \n",
    "- **Channel 2 (HCAL):** hadronic energy deposits — scaled by 1.0  \n",
    "\n",
    "The original `ParquetDataset` in `E2E_Regression_Anis_Ismail/data_utils.py` reads Parquet files and applies:\n",
    "- Per-channel scaling\n",
    "- Zero-suppression (`< 1e-3 → 0`)\n",
    "- High-value clipping (Tracker > 50, ECAL/HCAL > 5)\n",
    "- Mass target normalization: `mass / 500` (from `utils.py:transform_y`)\n",
    "\n",
    "Below we create a **dummy data generator** that mimics this structure for standalone prototyping."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Preprocessing utilities (from E2E_Regression_Anis_Ismail/utils.py) ──\n",
    "def transform_y(y, m0_scale=500.):\n",
    "    \"\"\"Scale mass target to [0,1] range.\"\"\"\n",
    "    return y / m0_scale\n",
    "\n",
    "def inv_transform(y, m0_scale=500.):\n",
    "    \"\"\"Inverse-scale mass back to GeV.\"\"\"\n",
    "    return y * m0_scale\n",
    "\n",
    "# ── Channel scaling factors from experiment.json ──\n",
    "CHANNEL_SCALES = [0.02, 0.2, 1.0]  # Tracker, ECAL, HCAL\n",
    "\n",
    "def preprocess_jet_image(x_jet):\n",
    "    \"\"\"\n",
    "    Preprocessing from E2E_Regression_Anis_Ismail/data_utils.py:\n",
    "    1. Per-channel scaling\n",
    "    2. Zero suppression (< 1e-3)\n",
    "    3. High-value clipping\n",
    "    \"\"\"\n",
    "    x_jet[0] = CHANNEL_SCALES[0] * x_jet[0]\n",
    "    x_jet[1] = CHANNEL_SCALES[1] * x_jet[1]\n",
    "    x_jet[2] = CHANNEL_SCALES[2] * x_jet[2]\n",
    "    x_jet[x_jet < 1.e-3] = 0.\n",
    "    x_jet[0][x_jet[0] > 50] = 1.\n",
    "    x_jet[1][x_jet[1] > 5] = 1.\n",
    "    x_jet[2][x_jet[2] > 5] = 1.\n",
    "    return x_jet"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate_dummy_detector_data(n_samples=2000, img_size=125, n_channels=3):\n",
    "    \"\"\"\n",
    "    Generate synthetic CMS-like detector data for prototyping.\n",
    "    Mimics the structure from ParquetDataset in data_utils.py.\n",
    "    \n",
    "    Returns:\n",
    "        images: (N, 3, 125, 125) - Tracker, ECAL, HCAL channels\n",
    "        labels: (N,) - binary classification (0=gluon, 1=quark)\n",
    "        masses: (N, 1) - generated mass in scaled units [0, 1]\n",
    "    \"\"\"\n",
    "    images = []\n",
    "    labels = []\n",
    "    masses = []\n",
    "    \n",
    "    for i in range(n_samples):\n",
    "        label = np.random.randint(0, 2)\n",
    "        \n",
    "        # Simulate sparse detector images (most pixels are zero)\n",
    "        img = np.zeros((n_channels, img_size, img_size), dtype=np.float32)\n",
    "        \n",
    "        # Create jet-like energy deposit pattern\n",
    "        cx, cy = img_size // 2 + np.random.randint(-10, 10), img_size // 2 + np.random.randint(-10, 10)\n",
    "        spread = 8 + label * 4  # quarks have wider jets\n",
    "        n_deposits = 40 + label * 20\n",
    "        \n",
    "        for _ in range(n_deposits):\n",
    "            dx = int(np.random.normal(0, spread))\n",
    "            dy = int(np.random.normal(0, spread))\n",
    "            px, py = cx + dx, cy + dy\n",
    "            if 0 <= px < img_size and 0 <= py < img_size:\n",
    "                energy = np.abs(np.random.exponential(2.0))\n",
    "                for ch in range(n_channels):\n",
    "                    img[ch, px, py] += energy * (0.5 + 0.5 * np.random.random())\n",
    "        \n",
    "        img = preprocess_jet_image(img)\n",
    "        images.append(img)\n",
    "        labels.append(label)\n",
    "        \n",
    "        # Mass: quarks ~ 170 GeV (top), gluons ~ 90 GeV\n",
    "        mass_gev = 170. + np.random.normal(0, 15) if label == 1 else 90. + np.random.normal(0, 10)\n",
    "        masses.append(transform_y(mass_gev))\n",
    "    \n",
    "    images = torch.tensor(np.array(images), dtype=torch.float32)\n",
    "    labels = torch.tensor(labels, dtype=torch.long)\n",
    "    masses = torch.tensor(masses, dtype=torch.float32).unsqueeze(1)\n",
    "    \n",
    "    return images, labels, masses\n",
    "\n",
    "# ── Generate data ��─\n",
    "print(\"Generating synthetic CMS detector data...\")\n",
    "images, labels, masses = generate_dummy_detector_data(n_samples=2000)\n",
    "print(f\"Images: {images.shape}\")\n",
    "print(f\"Labels: {labels.shape} — classes: {labels.unique().tolist()}\")\n",
    "print(f\"Masses: {masses.shape} — range: [{masses.min():.3f}, {masses.max():.3f}] (scaled)\")\n",
    "print(f\"Mass in GeV range: [{inv_transform(masses.min()):.1f}, {inv_transform(masses.max()):.1f}]\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Train / Val / Test split (pattern from data_utils.py train_val_loader) ──\n",
    "dataset = TensorDataset(images, labels, masses)\n",
    "n_total = len(dataset)\n",
    "n_train = int(0.8 * n_total)\n",
    "n_val = int(0.1 * n_total)\n",
    "n_test = n_total - n_train - n_val\n",
    "\n",
    "train_ds, val_ds, test_ds = random_split(\n",
    "    dataset, [n_train, n_val, n_test],\n",
    "    generator=torch.Generator().manual_seed(SEED)\n",
    ")\n",
    "\n",
    "BATCH_SIZE = 32\n",
    "train_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True, pin_memory=True, drop_last=True)\n",
    "val_loader = DataLoader(val_ds, batch_size=BATCH_SIZE, shuffle=False, pin_memory=True)\n",
    "test_loader = DataLoader(test_ds, batch_size=BATCH_SIZE, shuffle=False, pin_memory=True)\n",
    "\n",
    "print(f\"Train: {len(train_ds)}, Val: {len(val_ds)}, Test: {len(test_ds)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SECTION 4 — Convolutional Patch Embedding\n",
    "\n",
    "Instead of the standard ViT linear projection, we use a **convolutional stem** — a series of 3×3 convolutions with stride 2. This is inspired by the CoAtNet approach used in `E2E_Visual_Image_Transformer_Diptarko_Choudhury/Model/Quark_Gluon/coat.py` and the ResBlock pattern from `E2E_Regression_Anis_Ismail/models.py`.\n",
    "\n",
    "For 125×125 input → after two stride-2 convs → spatial size ~31×31 → then projected to sequence length N."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_conv_stem(in_chans, embed_dim):\n",
    "    \"\"\"\n",
    "    Convolutional patch embedding stem.\n",
    "    Two 3x3 conv layers with stride 2 + BatchNorm + GELU.\n",
    "    Input: (B, in_chans, 125, 125) → Output: (B, embed_dim, 31, 31)\n",
    "    \"\"\"\n",
    "    mid_dim = embed_dim // 2\n",
    "    return nn.Sequential(\n",
    "        nn.Conv2d(in_chans, mid_dim, kernel_size=3, stride=2, padding=1),\n",
    "        nn.BatchNorm2d(mid_dim),\n",
    "        nn.GELU(),\n",
    "        nn.Conv2d(mid_dim, embed_dim, kernel_size=3, stride=2, padding=1),\n",
    "        nn.BatchNorm2d(embed_dim),\n",
    "        nn.GELU(),\n",
    "    )\n",
    "\n",
    "# ── Verify spatial dimensions ──\n",
    "_stem = build_conv_stem(3, 128)\n",
    "_out = _stem(torch.randn(1, 3, 125, 125))\n",
    "print(f\"Conv stem output: {_out.shape}\")  # (1, 128, 32, 32)\n",
    "H_out, W_out = _out.shape[2], _out.shape[3]\n",
    "print(f\"Spatial size: {H_out}x{W_out} → sequence length N = {H_out * W_out}\")\n",
    "del _stem, _out"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SECTION 5 — XCiT Cross-Covariance Attention\n",
    "\n",
    "Standard attention: **Attn = softmax(Q·K^T / √d)·V** → shape (N×N), complexity O(N²d)\n",
    "\n",
    "XCiT attention: **Attn = softmax(Q̂^T · K̂ / τ)·V^T** → shape (d×d), complexity O(Nd²)\n",
    "\n",
    "Where Q̂ and K̂ are **L2-normalized** along the token dimension. The temperature τ is learnable.\n",
    "\n",
    "Since d (embed_dim per head) << N (number of spatial tokens), this is effectively **linear in N**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def xcit_cross_covariance_attention(q, k, v, temperature):\n",
    "    \"\"\"\n",
    "    XCiT cross-covariance attention.\n",
    "    \n",
    "    q, k, v: (B, num_heads, N, head_dim)\n",
    "    temperature: learnable scalar\n",
    "    \n",
    "    Returns: (B, num_heads, N, head_dim)\n",
    "    \"\"\"\n",
    "    # L2-normalize Q and K along the token dimension (critical for stability)\n",
    "    q = F.normalize(q, dim=-1)\n",
    "    k = F.normalize(k, dim=-1)\n",
    "    \n",
    "    # Cross-covariance: (B, H, d, d) instead of (B, H, N, N)\n",
    "    attn = torch.matmul(q.transpose(-2, -1), k) * temperature  # (B, H, d, d)\n",
    "    attn = F.softmax(attn, dim=-1)\n",
    "    \n",
    "    # Apply to values: V^T @ attn^T → (B, H, N, d)\n",
    "    out = torch.matmul(v, attn.transpose(-2, -1))  # (B, H, N, d)\n",
    "    return out\n",
    "\n",
    "# ── Verify ──\n",
    "B, H, N, d = 2, 4, 961, 32\n",
    "_q = torch.randn(B, H, N, d)\n",
    "_k = torch.randn(B, H, N, d)\n",
    "_v = torch.randn(B, H, N, d)\n",
    "_temp = nn.Parameter(torch.ones(1))\n",
    "_out = xcit_cross_covariance_attention(_q, _k, _v, _temp)\n",
    "print(f\"XCiT attention output: {_out.shape}\")  # (2, 4, 961, 32)\n",
    "del _q, _k, _v, _out"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SECTION 6 — L2ViT Local Concentration Module (LCM)\n",
    "\n",
    "The LCM adds a **3×3 depth-wise convolution** inside the attention computation. This provides:\n",
    "- Local spatial context that pure channel attention lacks\n",
    "- Prevention of the \"distribution concentration\" problem\n",
    "- Better locality-aware feature extraction for spatially structured detector images"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_local_concentration_module(dim, spatial_h, spatial_w):\n",
    "    \"\"\"\n",
    "    L2ViT Local Concentration Module.\n",
    "    3x3 depth-wise conv on the reshaped 2D feature map.\n",
    "    \"\"\"\n",
    "    return nn.Sequential(\n",
    "        nn.Conv2d(dim, dim, kernel_size=3, stride=1, padding=1, groups=dim),\n",
    "        nn.BatchNorm2d(dim),\n",
    "        nn.GELU(),\n",
    "    )\n",
    "\n",
    "# ── Verify ──\n",
    "_lcm = build_local_concentration_module(128, 32, 32)\n",
    "_x = torch.randn(2, 128, 32, 32)\n",
    "print(f\"LCM output: {_lcm(_x).shape}\")\n",
    "del _lcm, _x"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SECTION 7 — Conditional Positional Encoding (CPE)\n",
    "\n",
    "Instead of fixed or learned positional embeddings, we use **Conditional Positional Encoding** via a 3×3 depth-wise convolution. This is:\n",
    "- Resolution-agnostic (works for any spatial size)\n",
    "- Implicitly encodes local neighborhood structure\n",
    "- Used in XCiT and various modern ViT variants"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_conditional_positional_encoding(dim):\n",
    "    \"\"\"\n",
    "    Conditional Positional Encoding via depth-wise convolution.\n",
    "    Applied as: x = x + CPE(x)\n",
    "    \"\"\"\n",
    "    return nn.Sequential(\n",
    "        nn.Conv2d(dim, dim, kernel_size=3, stride=1, padding=1, groups=dim, bias=True),\n",
    "    )\n",
    "\n",
    "# ── Verify ──\n",
    "_cpe = build_conditional_positional_encoding(128)\n",
    "_x = torch.randn(2, 128, 32, 32)\n",
    "_out = _x + _cpe(_x)\n",
    "print(f\"CPE output: {_out.shape}\")\n",
    "del _cpe, _x, _out"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SECTION 8 — Transformer Block\n",
    "\n",
    "Each block combines:\n",
    "1. **Conditional Positional Encoding** (CPE)\n",
    "2. **XCiT Cross-Covariance Attention** with L2-normalized Q,K\n",
    "3. **L2ViT Local Concentration Module** (depth-wise conv)\n",
    "4. **Feed-Forward MLP** (expand → GELU → project)\n",
    "5. **Residual connections** + **LayerNorm**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class NextGenTransformerBlock(nn.Module):\n",
    "    \"\"\"\n",
    "    Single transformer block combining:\n",
    "    - CPE (conditional positional encoding)\n",
    "    - XCiT cross-covariance attention (L2-normed Q, K)\n",
    "    - L2ViT local concentration module\n",
    "    - FFN with residual connections\n",
    "    \"\"\"\n",
    "    def __init__(self, dim, num_heads, spatial_h, spatial_w, mlp_ratio=4.0, drop=0.0):\n",
    "        super().__init__()\n",
    "        self.dim = dim\n",
    "        self.num_heads = num_heads\n",
    "        self.head_dim = dim // num_heads\n",
    "        self.spatial_h = spatial_h\n",
    "        self.spatial_w = spatial_w\n",
    "        \n",
    "        # CPE\n",
    "        self.cpe = build_conditional_positional_encoding(dim)\n",
    "        \n",
    "        # Attention\n",
    "        self.norm1 = nn.LayerNorm(dim)\n",
    "        self.qkv = nn.Linear(dim, 3 * dim, bias=True)\n",
    "        self.temperature = nn.Parameter(torch.ones(num_heads, 1, 1) * 0.5)\n",
    "        self.attn_proj = nn.Linear(dim, dim)\n",
    "        self.attn_drop = nn.Dropout(drop)\n",
    "        \n",
    "        # LCM (L2ViT local concentration)\n",
    "        self.lcm = build_local_concentration_module(dim, spatial_h, spatial_w)\n",
    "        self.lcm_gate = nn.Parameter(torch.ones(1) * 0.5)\n",
    "        \n",
    "        # FFN\n",
    "        self.norm2 = nn.LayerNorm(dim)\n",
    "        mlp_hidden = int(dim * mlp_ratio)\n",
    "        self.ffn = nn.Sequential(\n",
    "            nn.Linear(dim, mlp_hidden),\n",
    "            nn.GELU(),\n",
    "            nn.Dropout(drop),\n",
    "            nn.Linear(mlp_hidden, dim),\n",
    "            nn.Dropout(drop),\n",
    "        )\n",
    "    \n",
    "    def forward(self, x):\n",
    "        B, N, C = x.shape\n",
    "        H, W = self.spatial_h, self.spatial_w\n",
    "        \n",
    "        # ── CPE: reshape → conv → reshape back ──\n",
    "        x_2d = x.transpose(1, 2).reshape(B, C, H, W)\n",
    "        x = x + self.cpe(x_2d).flatten(2).transpose(1, 2)\n",
    "        \n",
    "        # ── XCiT Attention ──\n",
    "        residual = x\n",
    "        x_norm = self.norm1(x)\n",
    "        qkv = self.qkv(x_norm).reshape(B, N, 3, self.num_heads, self.head_dim)\n",
    "        qkv = qkv.permute(2, 0, 3, 1, 4)  # (3, B, H, N, d)\n",
    "        q, k, v = qkv.unbind(0)\n",
    "        \n",
    "        attn_out = xcit_cross_covariance_attention(q, k, v, self.temperature)\n",
    "        attn_out = attn_out.transpose(1, 2).reshape(B, N, C)\n",
    "        attn_out = self.attn_proj(attn_out)\n",
    "        attn_out = self.attn_drop(attn_out)\n",
    "        \n",
    "        # ── L2ViT LCM: add local context ──\n",
    "        x_2d = x_norm.transpose(1, 2).reshape(B, C, H, W)\n",
    "        lcm_out = self.lcm(x_2d).flatten(2).transpose(1, 2)\n",
    "        \n",
    "        # Combine attention and local context with gated residual\n",
    "        x = residual + attn_out + self.lcm_gate * lcm_out\n",
    "        \n",
    "        # ── FFN ──\n",
    "        x = x + self.ffn(self.norm2(x))\n",
    "        \n",
    "        return x\n",
    "\n",
    "# ── Verify ──\n",
    "_block = NextGenTransformerBlock(dim=128, num_heads=4, spatial_h=32, spatial_w=32)\n",
    "_x = torch.randn(2, 32*32, 128)  # (B, N, C)\n",
    "_out = _block(_x)\n",
    "print(f\"Transformer block output: {_out.shape}\")\n",
    "del _block, _x, _out"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SECTION 9 — Multi-Task Output Heads\n",
    "\n",
    "The model produces two outputs:\n",
    "\n",
    "| Head | Task | Loss | Reference |\n",
    "|------|------|------|-----------|\n",
    "| **Classification** | Quark vs Gluon | CrossEntropyLoss | `run_train_test_parallel.py` (BCE) |\n",
    "| **Regression** | Mass prediction | MSE Loss | `metrics.py:mae_loss_wgtd`, `train_utils.py` |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_classification_head(embed_dim, num_classes):\n",
    "    \"\"\"Quark-Gluon classification head.\"\"\"\n",
    "    return nn.Sequential(\n",
    "        nn.LayerNorm(embed_dim),\n",
    "        nn.Linear(embed_dim, embed_dim // 2),\n",
    "        nn.GELU(),\n",
    "        nn.Dropout(0.1),\n",
    "        nn.Linear(embed_dim // 2, num_classes),\n",
    "    )\n",
    "\n",
    "def build_regression_head(embed_dim):\n",
    "    \"\"\"Mass regression head (outputs scaled mass).\"\"\"\n",
    "    return nn.Sequential(\n",
    "        nn.LayerNorm(embed_dim),\n",
    "        nn.Linear(embed_dim, embed_dim // 2),\n",
    "        nn.GELU(),\n",
    "        nn.Dropout(0.1),\n",
    "        nn.Linear(embed_dim // 2, 1),\n",
    "    )"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SECTION 10 — Functional Model Builder\n",
    "\n",
    "Following the specification, we use `nn.ModuleDict` to assemble the full architecture functionally. The `build_nextgen_vit` function returns a model with both classification and regression heads."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class NextGenViT(nn.Module):\n",
    "    \"\"\"\n",
    "    Next-Generation ViT for CMS E2E particle physics.\n",
    "    Combines: Conv stem + XCiT attention + L2ViT LCM + CPE + dual heads.\n",
    "    \"\"\"\n",
    "    def __init__(self, modules_dict):\n",
    "        super().__init__()\n",
    "        self.modules_dict = nn.ModuleDict(modules_dict)\n",
    "        self._spatial_h = None\n",
    "        self._spatial_w = None\n",
    "    \n",
    "    def set_spatial(self, h, w):\n",
    "        self._spatial_h = h\n",
    "        self._spatial_w = w\n",
    "    \n",
    "    def forward(self, x):\n",
    "        # ── Conv stem: (B, C, 125, 125) → (B, D, H, W) ──\n",
    "        x = self.modules_dict['conv_stem'](x)\n",
    "        B, D, H, W = x.shape\n",
    "        \n",
    "        # ── Flatten to sequence: (B, N, D) ──\n",
    "        x = x.flatten(2).transpose(1, 2)  # (B, H*W, D)\n",
    "        \n",
    "        # ── Transformer blocks ──\n",
    "        for key in sorted([k for k in self.modules_dict.keys() if k.startswith('block_')]):\n",
    "            x = self.modules_dict[key](x)\n",
    "        \n",
    "        # ── Global average pooling: (B, N, D) → (B, D) ──\n",
    "        x = x.mean(dim=1)\n",
    "        \n",
    "        # ── Dual heads ──\n",
    "        cls_logits = self.modules_dict['cls_head'](x)\n",
    "        mass_pred = self.modules_dict['reg_head'](x)\n",
    "        \n",
    "        return cls_logits, mass_pred\n",
    "\n",
    "\n",
    "def build_nextgen_vit(img_size=125, in_chans=3, num_classes=2,\n",
    "                      embed_dim=128, depth=4, num_heads=4, mlp_ratio=4.0, drop=0.1):\n",
    "    \"\"\"\n",
    "    Build the NextGen-ViT model.\n",
    "    \n",
    "    Architecture:\n",
    "        1. Conv stem (2× stride-2 convs)\n",
    "        2. N × Transformer blocks (XCiT + LCM + CPE)\n",
    "        3. Global average pooling\n",
    "        4. Classification head (Quark vs Gluon)\n",
    "        5. Regression head (mass)\n",
    "    \"\"\"\n",
    "    # Determine spatial size after conv stem\n",
    "    _stem = build_conv_stem(in_chans, embed_dim)\n",
    "    with torch.no_grad():\n",
    "        _dummy = torch.randn(1, in_chans, img_size, img_size)\n",
    "        _out = _stem(_dummy)\n",
    "        spatial_h, spatial_w = _out.shape[2], _out.shape[3]\n",
    "    del _dummy, _out\n",
    "    \n",
    "    print(f\"[build_nextgen_vit] Spatial after stem: {spatial_h}×{spatial_w} = {spatial_h*spatial_w} tokens\")\n",
    "    print(f\"[build_nextgen_vit] embed_dim={embed_dim}, depth={depth}, heads={num_heads}\")\n",
    "    \n",
    "    modules = {}\n",
    "    modules['conv_stem'] = _stem\n",
    "    \n",
    "    for i in range(depth):\n",
    "        modules[f'block_{i:02d}'] = NextGenTransformerBlock(\n",
    "            dim=embed_dim, num_heads=num_heads,\n",
    "            spatial_h=spatial_h, spatial_w=spatial_w,\n",
    "            mlp_ratio=mlp_ratio, drop=drop,\n",
    "        )\n",
    "    \n",
    "    modules['cls_head'] = build_classification_head(embed_dim, num_classes)\n",
    "    modules['reg_head'] = build_regression_head(embed_dim)\n",
    "    \n",
    "    model = NextGenViT(modules)\n",
    "    model.set_spatial(spatial_h, spatial_w)\n",
    "    \n",
    "    n_params = sum(p.numel() for p in model.parameters())\n",
    "    print(f\"[build_nextgen_vit] Total parameters: {n_params:,}\")\n",
    "    \n",
    "    return model\n",
    "\n",
    "# ── Build model ──\n",
    "model = build_nextgen_vit(\n",
    "    img_size=125, in_chans=3, num_classes=2,\n",
    "    embed_dim=128, depth=4, num_heads=4, mlp_ratio=4.0, drop=0.1\n",
    ")\n",
    "model = model.to(device)\n",
    "\n",
    "# ── Verify forward pass ──\n",
    "with torch.no_grad():\n",
    "    _x = torch.randn(2, 3, 125, 125).to(device)\n",
    "    _cls, _reg = model(_x)\n",
    "    print(f\"Classification output: {_cls.shape}\")  # (2, 2)\n",
    "    print(f\"Regression output: {_reg.shape}\")      # (2, 1)\n",
    "del _x, _cls, _reg"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SECTION 11 — Training Pipeline\n",
    "\n",
    "We use **AdamW** optimizer (as in Ka Wa Ho's `run_train_test_parallel.py`: `lr=0.0001, weight_decay=0.05`) with **ReduceLROnPlateau** scheduler (as in both Anis Ismail's `main.py` and Ka Wa Ho's config)."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## SECTION 12 — Custom Multi-Task Loss"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def multi_task_loss(cls_logits, cls_targets, reg_preds, reg_targets, alpha=1.0, beta=1.0):\n",
    "    \"\"\"\n",
    "    Combined multi-task loss.\n",
    "    \n",
    "    total_loss = alpha * CrossEntropyLoss(classification) + beta * MSELoss(regression)\n",
    "    \n",
    "    References:\n",
    "    - Classification: F.binary_cross_entropy_with_logits from run_train_test_parallel.py\n",
    "    - Regression: mae_loss_wgtd from E2E_Regression_Anis_Ismail/metrics.py\n",
    "    \"\"\"\n",
    "    cls_loss = F.cross_entropy(cls_logits, cls_targets)\n",
    "    reg_loss = F.mse_loss(reg_preds, reg_targets)\n",
    "    total = alpha * cls_loss + beta * reg_loss\n",
    "    return total, cls_loss, reg_loss"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Hyperparameters ──\n",
    "# AdamW config from Ka Wa Ho: lr=0.0001, weight_decay=0.05\n",
    "LR = 1e-4\n",
    "WEIGHT_DECAY = 0.05\n",
    "NUM_EPOCHS = 25\n",
    "ALPHA = 1.0  # classification loss weight\n",
    "BETA = 2.0   # regression loss weight (higher for emphasis)\n",
    "\n",
    "optimizer = optim.AdamW(model.parameters(), lr=LR, weight_decay=WEIGHT_DECAY)\n",
    "scheduler = optim.lr_scheduler.ReduceLROnPlateau(\n",
    "    optimizer, mode='min', factor=0.5, patience=3, threshold=0.001\n",
    ")\n",
    "\n",
    "print(f\"Optimizer: AdamW (lr={LR}, wd={WEIGHT_DECAY})\")\n",
    "print(f\"Scheduler: ReduceLROnPlateau (factor=0.5, patience=3)\")\n",
    "print(f\"Loss weights: alpha={ALPHA}, beta={BETA}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Training & Validation Loop ──\n",
    "# Adapted from E2E_Regression_Anis_Ismail/train_utils.py and run_train_test_parallel.py\n",
    "\n",
    "history = {\n",
    "    'train_loss': [], 'val_loss': [],\n",
    "    'train_cls_loss': [], 'val_cls_loss': [],\n",
    "    'train_reg_loss': [], 'val_reg_loss': [],\n",
    "    'train_acc': [], 'val_acc': [],\n",
    "    'train_mse': [], 'val_mse': [],\n",
    "}\n",
    "\n",
    "best_val_loss = float('inf')\n",
    "best_model_state = None\n",
    "\n",
    "print(f\"\\n{'='*70}\")\n",
    "print(f\"  Training NextGen-ViT for {NUM_EPOCHS} epochs\")\n",
    "print(f\"{'='*70}\\n\")\n",
    "\n",
    "for epoch in range(1, NUM_EPOCHS + 1):\n",
    "    t0 = time.time()\n",
    "    \n",
    "    # ── TRAIN ──\n",
    "    model.train()\n",
    "    train_total, train_cls, train_reg = 0., 0., 0.\n",
    "    train_correct, train_count = 0, 0\n",
    "    train_mse_sum = 0.\n",
    "    \n",
    "    for batch_imgs, batch_labels, batch_masses in train_loader:\n",
    "        batch_imgs = batch_imgs.to(device)\n",
    "        batch_labels = batch_labels.to(device)\n",
    "        batch_masses = batch_masses.to(device)\n",
    "        \n",
    "        optimizer.zero_grad()\n",
    "        cls_logits, reg_preds = model(batch_imgs)\n",
    "        loss, cls_loss, reg_loss = multi_task_loss(\n",
    "            cls_logits, batch_labels, reg_preds, batch_masses,\n",
    "            alpha=ALPHA, beta=BETA\n",
    "        )\n",
    "        loss.backward()\n",
    "        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n",
    "        optimizer.step()\n",
    "        \n",
    "        train_total += loss.item()\n",
    "        train_cls += cls_loss.item()\n",
    "        train_reg += reg_loss.item()\n",
    "        \n",
    "        preds = cls_logits.argmax(dim=1)\n",
    "        train_correct += (preds == batch_labels).sum().item()\n",
    "        train_count += batch_labels.size(0)\n",
    "        train_mse_sum += F.mse_loss(reg_preds, batch_masses, reduction='sum').item()\n",
    "    \n",
    "    n_train_batches = len(train_loader)\n",
    "    history['train_loss'].append(train_total / n_train_batches)\n",
    "    history['train_cls_loss'].append(train_cls / n_train_batches)\n",
    "    history['train_reg_loss'].append(train_reg / n_train_batches)\n",
    "    history['train_acc'].append(train_correct / train_count)\n",
    "    history['train_mse'].append(train_mse_sum / train_count)\n",
    "    \n",
    "    # ── VALIDATE ──\n",
    "    model.eval()\n",
    "    val_total, val_cls, val_reg = 0., 0., 0.\n",
    "    val_correct, val_count = 0, 0\n",
    "    val_mse_sum = 0.\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for batch_imgs, batch_labels, batch_masses in val_loader:\n",
    "            batch_imgs = batch_imgs.to(device)\n",
    "            batch_labels = batch_labels.to(device)\n",
    "            batch_masses = batch_masses.to(device)\n",
    "            \n",
    "            cls_logits, reg_preds = model(batch_imgs)\n",
    "            loss, cls_loss, reg_loss = multi_task_loss(\n",
    "                cls_logits, batch_labels, reg_preds, batch_masses,\n",
    "                alpha=ALPHA, beta=BETA\n",
    "            )\n",
    "            \n",
    "            val_total += loss.item()\n",
    "            val_cls += cls_loss.item()\n",
    "            val_reg += reg_loss.item()\n",
    "            \n",
    "            preds = cls_logits.argmax(dim=1)\n",
    "            val_correct += (preds == batch_labels).sum().item()\n",
    "            val_count += batch_labels.size(0)\n",
    "            val_mse_sum += F.mse_loss(reg_preds, batch_masses, reduction='sum').item()\n",
    "    \n",
    "    n_val_batches = len(val_loader)\n",
    "    history['val_loss'].append(val_total / n_val_batches)\n",
    "    history['val_cls_loss'].append(val_cls / n_val_batches)\n",
    "    history['val_reg_loss'].append(val_reg / n_val_batches)\n",
    "    history['val_acc'].append(val_correct / val_count)\n",
    "    history['val_mse'].append(val_mse_sum / val_count)\n",
    "    \n",
    "    # ── Scheduler step ──\n",
    "    scheduler.step(history['val_loss'][-1])\n",
    "    \n",
    "    # ── Best model tracking ──\n",
    "    if history['val_loss'][-1] < best_val_loss:\n",
    "        best_val_loss = history['val_loss'][-1]\n",
    "        best_model_state = {k: v.cpu().clone() for k, v in model.state_dict().items()}\n",
    "        marker = ' ★'\n",
    "    else:\n",
    "        marker = ''\n",
    "    \n",
    "    elapsed = time.time() - t0\n",
    "    current_lr = optimizer.param_groups[0]['lr']\n",
    "    \n",
    "    print(f\"Epoch {epoch:3d}/{NUM_EPOCHS} | \"\n",
    "          f\"Train Loss: {history['train_loss'][-1]:.4f} | \"\n",
    "          f\"Val Loss: {history['val_loss'][-1]:.4f} | \"\n",
    "          f\"Acc: {history['val_acc'][-1]:.3f} | \"\n",
    "          f\"MSE: {history['val_mse'][-1]:.5f} | \"\n",
    "          f\"LR: {current_lr:.1e} | \"\n",
    "          f\"{elapsed:.1f}s{marker}\")\n",
    "    \n",
    "    gc.collect()\n",
    "\n",
    "print(f\"\\nBest val loss: {best_val_loss:.4f}\")"
   ]
  },
