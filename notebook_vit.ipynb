    "print(f\"\\nRegression MSE:  {test_mse:.2f} GeV²\")\n",
    "print(f\"Regression MAE:  {test_mae:.2f} GeV\")\n",
    "print(f\"Regression MRE:  {test_mre:.4f}\")"
